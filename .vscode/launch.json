{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "nat-cli",
            "cargo": {
                "args": [
                    "build",
                    "--package=nat-cli",
                    "--bin=nat"
                ],
                "problemMatcher": [
                    "$rustc"
                ],
                "filter": {
                    "name": "nat",
                    "kind": "bin"
                }
            },
            "args": [
                // "${workspaceFolder}/nat.conf",
                "--toml=${workspaceFolder}/nat.toml"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "RUST_LOG": "debug"
            }
        }
    ]
}
